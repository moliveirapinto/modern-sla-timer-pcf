{
  "extends": "./node_modules/pcf-scripts/tsconfig_base.json",
  "compilerOptions": {
    "target": "ES2017",
    "module": "es2015",
    "lib": ["es2017", "dom"],
    "strict": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "out",
    "rootDir": ".",
    "moduleResolution": "node",
    "skipLibCheck": true,
    "typeRoots": ["node_modules/@types"]
  },
  "include": ["ModernSlaTimerControl/**/*"]
}
