<?xml version="1.0" encoding="utf-8" ?>
<manifest>
  <control namespace="ModernSlaTimer" constructor="ModernSlaTimerControl" version="1.0.1"
    display-name-key="Modern SLA Timer"
    description-key="A modern, visually appealing SLA Timer control for Dynamics 365 Case forms"
    control-type="standard" api-version="1.3.18">

    <external-service-usage enabled="false" />

    <data-set name="dataSetGrid_1" display-name-key="SLA KPI Instances" />

    <property name="EnableNegativeTimer" display-name-key="Enable Negative Timer"
      description-key="Show negative time after SLA breach" of-type="Enum"
      usage="input" required="false" default-value="0">
      <value name="0" display-name-key="No">0</value>
      <value name="1" display-name-key="Yes">1</value>
    </property>

    <resources>
      <code path="index.ts" order="1" />
      <css path="css/ModernSlaTimerControl.css" order="1" />
    </resources>

    <feature-usage />
  </control>
</manifest>
